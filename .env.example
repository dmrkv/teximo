# Copy to .env (gitignored) — never commit .env

# Apple Developer account used for notarization
NOTARIZE_APPLE_ID=your_apple_id@example.com
NOTARIZE_TEAM_ID=YOUR_TEAM_ID

# App-specific password from https://appleid.apple.com → Sign-In and Security
# Revoke any password that was ever committed to git and create a new one.
NOTARIZE_PASSWORD=xxxx-xxxx-xxxx-xxxx

# After running ./scripts/setup_notary_keychain.sh, prefer the keychain profile:
# NOTARIZE_KEYCHAIN_PROFILE=teximo-notarize

# Optional: Developer ID identity (auto-detected if unset)
# SIGNING_IDENTITY="Developer ID Application: Your Name (YOUR_TEAM_ID)"

# Optional: DMG background image for create_signed_release.sh
# DMG_BACKGROUND_IMG=/path/to/dmg_background.png
